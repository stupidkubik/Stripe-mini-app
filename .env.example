STRIPE_SECRET_KEY=stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=stripe_webhook_secret_here

# Optional dedicated HMAC key for per-session receipt cookies. When omitted,
# the server derives proofs with STRIPE_SECRET_KEY.
# RECEIPT_SIGNING_SECRET=replace_with_a_long_random_secret

# Durable order/event/outbox storage. Vercel Marketplace Postgres integrations
# normally inject DATABASE_URL automatically.
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Trusted server-side origin used for Checkout success/cancel URLs.
SITE_URL=http://localhost:3000

# Public origin used for metadata/sitemap URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Single currency accepted by the catalogue, cart, and Checkout.
NEXT_PUBLIC_STOREFRONT_CURRENCY=USD

# Optional: allow /success preview mode for unpaid sessions outside dev.
DEMO_SUCCESS=false

# Optional rate-limit overrides (defaults are safe for local/dev).
RATE_LIMIT_CHECKOUT_MAX=30
RATE_LIMIT_CHECKOUT_WINDOW_MS=60000
STRIPE_API_BUDGET_MAX=300
STRIPE_API_BUDGET_WINDOW_MS=60000

# Maximum request bodies buffered by application routes.
CHECKOUT_MAX_BODY_BYTES=16384
STRIPE_WEBHOOK_MAX_BODY_BYTES=1048576

# Set by the hosting platform, not by users. Rate limiting trusts only
# x-vercel-forwarded-for on Vercel or cf-connecting-ip on Cloudflare Pages.
# The application limits are defense in depth and remain process-local. Enable
# a shared edge/WAF rate-limit rule for /api/checkout in multi-instance production.
# VERCEL=1
# CF_PAGES=1
